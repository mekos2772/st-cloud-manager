# ==================== ST Cloud Manager ====================

# --- Paths ---
ST_DB_PATH=data.db
ST_USERS_DIR=users
ST_ARCHIVE_DIR=archive
ST_TEMPLATES_DIR=templates

# --- Docker ---
ST_DOCKER_NETWORK=st_proxy
ST_DOCKER_IMAGE=ghcr.io/sillytavern/sillytavern:latest
ST_DOCKER_MEMORY=768m

# --- Traefik ---
# Local:      ST_TRAEFIK_ENTRYPOINT=web     ST_TRAEFIK_TLS=false  ST_PUBLIC_SCHEME=http
# Production: ST_TRAEFIK_ENTRYPOINT=websecure ST_TRAEFIK_TLS=true  ST_PUBLIC_SCHEME=https
ST_TRAEFIK_ENTRYPOINT=web
ST_TRAEFIK_TLS=false
ST_TRAEFIK_CERT_RESOLVER=le
ST_PUBLIC_SCHEME=http

# Domain suffix for instances (no leading dot)
# Local:  ST_DOMAIN_SUFFIX=127-0-0-1.sslip.io
# Prod:   ST_DOMAIN_SUFFIX=st.example.com
ST_DOMAIN_SUFFIX=127-0-0-1.sslip.io

# Manager subdomain (optional, defaults to manager.<DOMAIN_SUFFIX>)
# ST_MANAGER_DOMAIN=manager.127-0-0-1.sslip.io

# --- API Proxy (LiteLLM / One API / New API) ---
ST_PROXY_BASE_URL=https://api-proxy.example.com/v1
ST_PROXY_MASTER_KEY=
ST_API_BASE_URL=http://api.lordfa.top
ST_API_MODEL=deepseek-v4-pro

# --- Instance Defaults ---
ST_DEFAULT_PLAN=default
ST_DEFAULT_DAYS=30

# --- Admin ---
ST_ADMIN_API_KEY=test-admin-key

# --- ACME (prod only) ---
# ACME_EMAIL=admin@example.com
